# Emprinte landing site (Next.js) — copy to .env.local locally; set in Vercel for production.
# Deploy: see DEPLOY.md (Vercel project "emprinte" on Quadmor's team).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public site URL for Paystack return links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.emprintereaders.com

# Paystack — use test keys until checkout is verified end-to-end
PAYSTACK_SECRET_KEY=sk_test_...
# Optional: separate webhook secret from Paystack dashboard (defaults to PAYSTACK_SECRET_KEY)
# PAYSTACK_WEBHOOK_SECRET=

NEXT_PUBLIC_WORKSHOP_SLUG=practical-steps-financial-independence

# Cloudinary — blog hero uploads and admin image crops (required for “Upload image” in /admin/blog)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional upload folder (default: emprinte/blog)
# CLOUDINARY_UPLOAD_FOLDER=emprinte/blog

# Optional — only if you run a separate auth API (see src/constants/auth-api.ts).
# Do NOT set on Vercel for the marketing site; it breaks public Server Component data loads.
# NEXT_PUBLIC_API_URL=http://localhost:3001
